# ============================================================
#  All variables are OPTIONAL. The site runs fully without them;
#  these just switch on the AI widget and the persistent guestbook.
#  (The contact form uses Formspree — no key needed.)
# ============================================================

# --- AI "Ask my portfolio" widget — via OpenRouter (free models) ---
# Get a key at https://openrouter.ai/keys  (no credit card needed for free models)
OPENROUTER_API_KEY=sk-or-v1-xxxx
# Optional: pin a specific free model. Default is "openrouter/free" (auto-picks a free one).
# Examples: meta-llama/llama-3.3-70b-instruct:free | deepseek/deepseek-r1:free | google/gemma-2-9b-it:free
# Browse current free models: https://openrouter.ai/models  (filter price = Free)
# OPENROUTER_MODEL=openrouter/free
# Optional: your live URL, used in OpenRouter request headers
# SITE_URL=https://your-site.vercel.app

# --- Guestbook + view counter (https://upstash.com — free serverless Redis) ---
# Without these, they run in-memory (reset on redeploy) so the app still works.
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxx
